  export NODE_PATH="/Users/zhangxinxin/Desktop/projects/lowcode/node_modules/.pnpm/unbuild@3.6.1_typescript@5.9.3/node_modules/unbuild/dist/node_modules:/Users/zhangxinxin/Desktop/projects/lowcode/node_modules/.pnpm/unbuild@3.6.1_typescript@5.9.3/node_modules/unbuild/node_modules:/Users/zhangxinxin/Desktop/projects/lowcode/node_modules/.pnpm/unbuild@3.6.1_typescript@5.9.3/node_modules:/Users/zhangxinxin/Desktop/projects/lowcode/node_modules/.pnpm/node_modules:$NODE_PATH"
